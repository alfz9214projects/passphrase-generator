{
  "manifest_version": 3,
  "name": "Passphrase Generator - A Washy Witness GB Project",
  "version": "0.1",
  "description": "Encrypted password manager with passphrase generator",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["inject.css"]
    }
  ]
}
